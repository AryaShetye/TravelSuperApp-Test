# ============================================
# Travel Super App - Backend Environment Variables
# Copy this file to .env and fill in values
# ============================================

# Server
PORT=5000
NODE_ENV=development

# JWT Authentication
JWT_SECRET=your_jwt_secret_here_min_32_chars
JWT_EXPIRES_IN=7d

# ─── Database Mode ────────────────────────────────────────────────────────────
# Set USE_MEMORY_DB=true for local development (no external DB needed)
# Set USE_MEMORY_DB=false to use real Firebase Firestore
USE_MEMORY_DB=true

# ─── Firebase (required when USE_MEMORY_DB=false) ─────────────────────────────
# Get from Firebase Console → Project Settings → Service Accounts → Generate key
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"

# Cloudinary (Image uploads) — https://cloudinary.com
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Razorpay (Payments) — https://razorpay.com
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret

# OpenStreetMap — NO API KEY REQUIRED (free & open)
OSM_USER_AGENT=TravelSuperApp/1.0 (your@email.com)

# Twilio (SMS) — https://twilio.com
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# ─── SerpAPI (Real-time travel data) ─────────────────────────────────────────
# Get your free key at: https://serpapi.com (100 free searches/month)
# Used for: Hotels, Flights, Attractions, Destinations
# Leave blank to use free fallback data (OSM + curated)
SERPAPI_KEY=your_serpapi_key_here
